# Ave API (required)
AVE_API_KEY=
AVE_API_SECRET=
AVE_BASE_URL=https://bot-api.ave.ai
AVE_WSS_URL=wss://bot-api.ave.ai/thirdws
AVE_DATA_WSS_URL=wss://wss.ave-api.xyz

# Telegram Bot (optional — can be configured from the dashboard UI)
TELEGRAM_BOT_TOKEN=

# Server
PORT=3001
# Set this to your Vercel frontend URL after deploying
FRONTEND_URL=https://your-app.vercel.app

# Defaults
DEFAULT_CHAIN=bsc
DEMO_MODE=true
